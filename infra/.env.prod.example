# Copy to infra/.env and fill in real values, then:
#   docker compose -f infra/docker-compose.prod.yml --env-file infra/.env up -d --build
#
# NEVER commit the real infra/.env — it holds production secrets.

APP_NAME="Fitness Attendance"
# Public URL staff/mobile clients use to reach the API.
APP_URL=https://api.example.com
# Host port the Nginx container is published on (put a real reverse proxy /
# TLS terminator such as a managed load balancer or Caddy in front of this).
APP_PORT=80

# Generate a fresh key for this environment — do NOT reuse the dev key:
#   docker compose -f infra/docker-compose.prod.yml run --rm app php artisan key:generate --show
APP_KEY=

DB_DATABASE=fitness_attendance
DB_USERNAME=fitness_attendance
# Use a long, random, unique password (e.g. `openssl rand -base64 32`).
DB_PASSWORD=

# Static export of the Expo web build only (see infra/README.md) — the
# iOS/Android apps ship separately via EAS Build, not this compose file.
# Set this to the same host as APP_URL above, plus /api/v1.
MOBILE_PORT=8081
MOBILE_API_URL=https://api.example.com/api/v1
