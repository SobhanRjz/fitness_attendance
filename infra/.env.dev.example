# Copy to infra/.env and adjust if needed, then:
#   docker compose -f infra/docker-compose.dev.yml --env-file infra/.env up --build
#
# These values are for local development only — never reuse them anywhere else.

APP_NAME="Fitness Attendance"
APP_URL=http://localhost:8000
APP_PORT=8000

# Dev-only key, safe to commit/share — it protects nothing real. Generate your
# own any time with: docker compose -f infra/docker-compose.dev.yml run --rm app php artisan key:generate --show
APP_KEY=base64:Slga3MCqIKYqLwP6nA7hJwsuIDfc/tbpUoz1AtO6aqs=

DB_DATABASE=fitness_attendance
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# Web preview only (see infra/README.md) — for a physical device/simulator,
# use `npm start` on the host instead, as documented in the root README.
MOBILE_PORT=8081
MOBILE_API_URL=http://localhost:8000/api/v1
