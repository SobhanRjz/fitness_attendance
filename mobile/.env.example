# Copy this file to .env and adjust as needed.
#
# Default (Android emulator / iOS simulator, backend on the same machine):
# leave this unset — env.ts already picks the right localhost/10.0.2.2 default.
#
# Physical device: set this to your machine's LAN IP so the phone can reach
# the backend, and start the backend with:
#   php artisan serve --host=0.0.0.0 --port=8000
EXPO_PUBLIC_API_URL=http://192.168.1.100:8000/api/v1
